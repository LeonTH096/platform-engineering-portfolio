# Gitattributes — line ending normalization and diff behavior

* text=auto eol=lf

*.tf text eol=lf diff=hcl
*.tfvars text eol=lf diff=hcl
*.hcl text eol=lf diff=hcl
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.go text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.env text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.tpl text eol=lf
*.txt text eol=lf
*.csv text eol=lf
LICENSE text eol=lf

.terraform.lock.hcl linguist-generated=true merge=binary

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

*.zip binary
*.tar.gz binary
*.tgz binary

*.pem binary
*.der binary
*.p12 binary
